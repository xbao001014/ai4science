# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ── PubMed / NCBI ─────────────────────────────────────────────────────────────
PUBMED_API_KEY=your_pubmed_api_key
PUBMED_EMAIL=your@email.com

# ── Semantic Scholar ──────────────────────────────────────────────────────────
S2_API_KEY=your_semantic_scholar_api_key

# ── LLM (OpenAI-compatible; e.g. 百炼 DashScope / DeepSeek) ─────────────────
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_dashscope_api_key
# OPENAI_API_KEY=your_openai_compatible_key
# DEEPSEEK_API_KEY=your_deepseek_key
LLM_MODEL=deepseek-v4-flash
LLM_MODEL_EXTRACT=deepseek-v4-flash
LLM_MODEL_AGENT=qwen3.7-plus
LLM_MAX_TOKENS=32768
LLM_MAX_INPUT_CHARS=800000
LLM_MAX_TOOL_RESULT_CHARS=100000
LLM_MIN_INTERVAL=2.0
LLM_MAX_CONCURRENT=1
LLM_RETRY_ATTEMPTS=6
LLM_RETRY_DELAY=3.0
LLM_REQUEST_TIMEOUT=180
LLM_RATE_LIMIT_COOLDOWN=45
TOOL_TOP_N=30
GRAPH_TOP_N=25

# ── PubMed search scope (fulltext_workflow) ───────────────────────────────────
FULLTEXT_SEARCH_YEAR_START=2015
FULLTEXT_SEARCH_YEAR_END=2026
FETCH_EDAT_DAYS=14

# Weekly hotspot (fulltext_workflow)
HOTSPOT_WINDOW_DAYS=14
HOTSPOT_PRIOR_WINDOW_DAYS=14
HOTSPOT_MIN_RECENT_PAPERS=2

# ── Extraction speed (fulltext_workflow) ──────────────────────────────────────
EXTRACT_CORE_ONLY=true
EXTRACT_SECTION_WORKERS=1
EXTRACT_PAPER_WORKERS=1
EXTRACT_MAX_SECTION_CHARS=12000
EXTRACT_SKIP_STUDY_LLM=true

# ── Pathology data API (feasibility assessment) ───────────────────────────────
PATHOLOGY_API_BASE_URL=http://your-pathology-api-host/api/v1/pathology
PATHOLOGY_API_KEY=your_pathology_api_key
PATHOLOGY_DATA_PROVIDER=api
PATHOLOGY_BOOTSTRAP_MIN_CASES=1

# ── Neo4j (optional) ──────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
USE_NEO4J=false
